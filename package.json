{
  "name": "fastmail-mcp-unofficial",
  "version": "0.5.0",
  "description": "MCP server for Fastmail — JMAP execute proxy",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "pnpm build:apps && tsc",
    "build:apps": "INPUT=apps/read-email.html vite build -c vite.apps.config.ts && INPUT=apps/compose.html vite build -c vite.apps.config.ts",
    "start": "node dist/index.js",
    "deploy": "vercel --prod",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "fmt": "oxfmt --write src",
    "fmt:check": "oxfmt --check src",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm typecheck && pnpm lint && pnpm fmt:check && pnpm test",
    "prepare": "lefthook install"
  },
  "keywords": [
    "mcp",
    "fastmail",
    "jmap",
    "email"
  ],
  "author": "Ilnur Khalilov <i@khl.lv>",
  "license": "MIT",
  "dependencies": {
    "@hono/mcp": "^0.2.4",
    "@hono/node-server": "^1.19.7",
    "@modelcontextprotocol/ext-apps": "^1.2.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "cheerio": "^1.2.0",
    "hono": "^4.9.8",
    "redis": "^5.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "lefthook": "^2.1.0",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "typescript": "^5.9.2",
    "vercel": "^39.2.4",
    "vite": "^8.0.0",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^4.0.18"
  }
}
