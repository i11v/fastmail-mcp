{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"skipLibCheck": true,
		"lib": ["ESNext"],
		"isolatedModules": true,
		"noEmit": true,
		"types": ["./worker-configuration.d.ts"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "src/__tests__"]
}
